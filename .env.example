# VerifyIQ Regression Runner — environment configuration

# --------------------------------------------------------------------------
# Staging environment (default)
# --------------------------------------------------------------------------
STAGING_URL=https://ai-boostform-api-1019050071398.us-central1.run.app
VERIFYIQ_API_KEY=your-staging-tenant-api-key

# --------------------------------------------------------------------------
# Dev environment  (used when --env dev or TARGET_ENV=dev)
# --------------------------------------------------------------------------
DEV_URL=https://parser-dev.boostkh.com
DEV_VERIFYIQ_API_KEY=your-dev-tenant-api-key

# --------------------------------------------------------------------------
# Google Cloud / IAP (required for staging batch uploads and IAP-gated paths)
# --------------------------------------------------------------------------
GOOGLE_SA_KEY_FILE=path/to/service-account.json

# --------------------------------------------------------------------------
# Webhook server (optional — batch tests skip gracefully when unset)
# Dev has no webhook server; leave WEBHOOK_SERVER_URL unset for dev runs.
# --------------------------------------------------------------------------
WEBHOOK_SERVER_URL=https://verifyiq-webhook-server-1019050071398.us-central1.run.app

# --------------------------------------------------------------------------
# ClickUp reporting
# Staging runs post to CLICKUP_FOLDER_ID / CLICKUP_LIST_ID.
# Dev runs post to DEV_CLICKUP_FOLDER_ID / DEV_CLICKUP_LIST_ID (fall back
# to the staging values when the dev-specific vars are not set).
# --------------------------------------------------------------------------
CLICKUP_API_TOKEN=your-clickup-token
CLICKUP_FOLDER_ID=90147720582
CLICKUP_LIST_ID=901415181079
DEV_CLICKUP_FOLDER_ID=
DEV_CLICKUP_LIST_ID=

# --------------------------------------------------------------------------
# Slack notifications (optional)
# --------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
