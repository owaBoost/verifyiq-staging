# VerifyIQ Regression Runner — environment configuration

# --------------------------------------------------------------------------
# Staging environment (default)
# --------------------------------------------------------------------------
STAGING_URL=https://ai-boostform-api-1019050071398.us-central1.run.app
VERIFYIQ_API_KEY=your-staging-tenant-api-key

# --------------------------------------------------------------------------
# Dev environment  (used when --env dev or TARGET_ENV=dev)
# --------------------------------------------------------------------------
DEV_URL=https://parser-dev.boostkh.com
DEV_VERIFYIQ_API_KEY=your-dev-tenant-api-key

# --------------------------------------------------------------------------
# PR preview environments  (used when --env pr)
#   --pr <number>    builds the URL from PR_URL_TEMPLATE, replacing {n}
#   --base-url <url> uses the URL directly (CI should pass this)
# --------------------------------------------------------------------------
PR_URL_TEMPLATE=https://ai-parser-pr-{n}-z6thvhgnxa-uc.a.run.app

# Cloud Run auth for PR services.
# "none"     — unauthenticated (default; Cloud Run allows allUsers)
# "id-token" — attach Google-signed ID token (Cloud Run invoker role);
#              requires GOOGLE_SA_KEY_FILE
# TODO: verify correct mode against a live PR environment.
PR_AUTH_MODE=none

# --------------------------------------------------------------------------
# Google Cloud / IAP (required for staging batch uploads / IAP-gated paths,
# and for PR environments when PR_AUTH_MODE=id-token)
# --------------------------------------------------------------------------
GOOGLE_SA_KEY_FILE=path/to/service-account.json

# --------------------------------------------------------------------------
# Webhook server (optional — batch tests skip gracefully when unset)
# Dev and PR environments have no webhook server; leave this unset for those.
# --------------------------------------------------------------------------
WEBHOOK_SERVER_URL=https://verifyiq-webhook-server-1019050071398.us-central1.run.app

# --------------------------------------------------------------------------
# ClickUp reporting
# All environments report to the same folder; lists are named per env + date:
#   staging -> "Regression [staging] YYYY-MM-DD"
#   dev     -> "Regression [dev] YYYY-MM-DD"
#   pr      -> "Regression [pr-487] YYYY-MM-DD"
# --------------------------------------------------------------------------
CLICKUP_API_TOKEN=your-clickup-token
CLICKUP_FOLDER_ID=90147720582
CLICKUP_LIST_ID=901415181079

# --------------------------------------------------------------------------
# Slack notifications (optional)
# --------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
